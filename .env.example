# Copy this file to .env and fill in your values.
# Used by: ingest.py, load_neo4j.py, briefings.py, api/main.py

# Anthropic (required for the /ask endpoint)
ANTHROPIC_API_KEY=

# Neo4j connection (required)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# FastAPI backend URL (used by the Next.js frontend)
# Set to http://localhost:8000 for local development.
NEXT_PUBLIC_API_URL=http://localhost:8000
